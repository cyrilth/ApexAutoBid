# Template for the environment variables auth.ts (and friends) read.
#
# For local development you don't need to copy this anywhere -- .env
# already commits working dev defaults matching
# backend/IdentityService/Config.cs's "webapp" client (Docs/Requirements.md
# §6 treats these as throwaway, local-only values, safe to commit like
# appsettings.Development.json on the backend).
#
# Use this file as a reference when setting real values for a non-local
# environment (copy to .env.local to override the committed .env without
# editing it, or set these directly wherever that environment's deployment
# mechanism injects env vars -- see Docs/Requirements.md §6 for
# Docker Compose / Kubernetes / CI conventions). Kubernetes Secrets and
# CI/CD environments must NOT get their values from this file being copied
# verbatim -- generate a fresh AUTH_SECRET and use that environment's real
# IdentityServer client credentials.

# --- Auth.js -----------------------------------------------------------
# Generate with `openssl rand -base64 33` (or `npx auth secret`).
AUTH_SECRET=
# Public base URL of this app.
AUTH_URL=http://localhost:3000
# Required when self-hosting (not on Vercel).
AUTH_TRUST_HOST=true

# --- IdentityServer ("webapp" client, backend/IdentityService/Config.cs) ---
AUTH_IDENTITYSERVER_ISSUER=https://localhost:5001
AUTH_IDENTITYSERVER_ID=webapp
AUTH_IDENTITYSERVER_SECRET=

# Dev-only. Never set this in a real deployment. See lib/dev-tls.ts.
AUTH_IDENTITYSERVER_ALLOW_INSECURE_TLS=

# --- Gateway (Architecture.md §3.5) -------------------------------------
# Server-only base URL for all API calls (e.g. lib/search-service.ts) --
# never call a backend service directly, always through the Gateway.
GATEWAY_URL=http://localhost:6001

# Browser-facing base URL for the same Gateway, used only by the SignalR
# HubConnection (lib/signalr.ts), which runs in the browser and so needs a
# URL the browser itself can resolve -- NEXT_PUBLIC_ vars are inlined into
# the client bundle at build time. On a LAN/remote client machine
# "localhost" only resolves to that machine itself -- set this to a real
# reachable hostname once this app is deployed (docker-compose/k8s phases).
NEXT_PUBLIC_GATEWAY_URL=http://localhost:6001
