# Template for the environment variables auth.ts (and friends) read.
#
# Local development setup: copy this file to `.env` (gitignored) and fill
# in the two blank secrets below -- everything else already carries the
# correct local-dev value. `.env` is machine-local and never committed;
# each machine keeps its own copy.
#
# Non-local environments must NOT copy this file verbatim -- generate a
# fresh AUTH_SECRET and use that environment's real IdentityServer client
# credentials, injected via that environment's deployment mechanism
# (Docker Compose / Kubernetes Secrets / CI -- see Docs/Requirements.md §6).

# --- Auth.js -----------------------------------------------------------
# Generate with `openssl rand -base64 33` (or `npx auth secret`).
AUTH_SECRET=
# Public base URL of this app.
AUTH_URL=http://localhost:3000
# Required when self-hosting (not on Vercel).
AUTH_TRUST_HOST=true

# --- IdentityServer ("webapp" client, backend/IdentityService/Config.cs) ---
AUTH_IDENTITYSERVER_ISSUER=https://localhost:5001
AUTH_IDENTITYSERVER_ID=webapp
# For local dev: the "webapp" client's dev secret registered in
# backend/IdentityService/Config.cs.
AUTH_IDENTITYSERVER_SECRET=

# Dev-only: set to `true` locally so next-auth's server-side token exchange
# tolerates the self-signed ASP.NET Core dev HTTPS certificate (or run
# `dotnet dev-certs https --trust` once and leave this unset). Hard-guarded
# to never apply when NODE_ENV=production -- see lib/dev-tls.ts. Never set
# this in a real deployment.
AUTH_IDENTITYSERVER_ALLOW_INSECURE_TLS=

# --- Gateway (Architecture.md §3.5) -------------------------------------
# Server-only base URL for all API calls (e.g. lib/search-service.ts) --
# never call a backend service directly, always through the Gateway.
GATEWAY_URL=http://localhost:6001

# Browser-facing base URL for the same Gateway, used only by the SignalR
# HubConnection (lib/signalr.ts), which runs in the browser and so needs a
# URL the browser itself can resolve -- NEXT_PUBLIC_ vars are inlined into
# the client bundle at build time. On a LAN/remote client machine
# "localhost" only resolves to that machine itself -- set this to a real
# reachable hostname once this app is deployed (docker-compose/k8s phases).
NEXT_PUBLIC_GATEWAY_URL=http://localhost:6001

# --- Image optimization (Phase 7 Task 12, lib/image-config.ts) ---------
# Object-storage host serving auction images/thumbnails (MinIO in dev, any
# S3-compatible host in production -- mirrors the Auction Service's
# `Images:PublicBaseUrl`). Browser-facing like NEXT_PUBLIC_GATEWAY_URL above,
# since CarImage checks it client-side to decide whether an image src is
# safe to optimize. next.config.ts's `images.remotePatterns` reads the same
# value at build time -- changing this in production requires a rebuild.
NEXT_PUBLIC_IMAGE_STORAGE_URL=http://localhost:9000
