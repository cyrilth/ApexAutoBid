# Dev-only values -- committed by design (Docs/Requirements.md §6, same
# convention as backend/**/appsettings.Development.json). Nothing here
# grants access to a non-local resource. Override any of these locally
# without touching this file by adding a (gitignored) .env.local.

# --- Auth.js -----------------------------------------------------------
# Generated with `openssl rand -base64 33`. Fine to share across dev
# machines since it only protects local sessions against a local app --
# rotate before ever reusing this repo's dev setup for anything real.
AUTH_SECRET=TBaXY0jK2BWFG+OqoBi+/Oob58sQsvkd9vZdboDZgZXU
AUTH_URL=http://localhost:3000
# Required for self-hosted (non-Vercel) deployments -- see auth.ts's
# `trustHost: true`, which does the same thing explicitly in code.
AUTH_TRUST_HOST=true

# --- IdentityServer ("webapp" client) -----------------------------------
# Must match backend/IdentityService/Config.cs exactly.
AUTH_IDENTITYSERVER_ISSUER=https://localhost:5001
AUTH_IDENTITYSERVER_ID=webapp
AUTH_IDENTITYSERVER_SECRET=webapp-dev-secret

# Dev-only: lets next-auth's server-side token exchange tolerate the
# self-signed ASP.NET Core dev HTTPS certificate. See lib/dev-tls.ts --
# this is hard-guarded to never apply when NODE_ENV=production regardless
# of this flag. Unset this (or run `dotnet dev-certs https --trust` once)
# if you'd rather not relax TLS checks at all.
AUTH_IDENTITYSERVER_ALLOW_INSECURE_TLS=true

# --- Gateway (Architecture.md §3.5) -------------------------------------
# Server-only: all API calls (e.g. lib/search-service.ts) go through the
# Gateway, never a backend service directly. Matches
# backend/GatewayService/Properties/launchSettings.json's "http" profile.
GATEWAY_URL=http://localhost:6001

# Browser-facing Gateway base URL (Phase 7 Task 8.2/8.3) -- SignalR's
# HubConnection runs IN the browser (lib/signalr.ts), so it needs a URL the
# browser itself can resolve, distinct from the server-only GATEWAY_URL
# above. NEXT_PUBLIC_ vars are inlined into the client bundle at build time.
# On a LAN/remote client machine "localhost" only resolves to that machine
# itself, not the server running the Gateway -- a real reachable hostname
# goes here once this app is deployed (docker-compose/k8s phases).
NEXT_PUBLIC_GATEWAY_URL=http://localhost:6001
