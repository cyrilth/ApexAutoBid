meta {
  name: Create Upload URL
  type: http
  seq: 6
}

post {
  url: {{auction}}/api/auctions/upload-url
  body: json
  auth: inherit
}

body:json {
  {
    "contentType": "image/jpeg",
    "sizeBytes": 415
  }
}

docs {
  sizeBytes MUST equal the exact byte count of what gets PUT: the presigned URL
  signs Content-Length (and Content-Type), so a mismatched upload fails with 403
  SignatureDoesNotMatch. The value above is the exact size of the tiny JPEG the
  post-response script uploads.

  Returns a presigned MinIO PUT URL + a GUID object key + expiry. Upload flow:
  1) call this, 2) PUT the raw image bytes to the returned URL (no auth header —
  the signature is in the URL), 3) pass the key to Generate Thumbnail, 4) reference
  the public object URL in Create Auction's images array.

  Negative cases: contentType "application/pdf" → 400; sizeBytes over the configured
  limit → 400; no token → 401.
}

assert {
  res.status: eq 200
  res.body.key: isDefined
  res.body.uploadUrl: isDefined
  res.body.objectUrl: isDefined
}

script:post-response {
  // Complete step 2 of the upload flow right here so Generate Thumbnail (seq 7) has a
  // real object to work on in a headless CLI run: PUT a minimal 1x1 JPEG to the
  // presigned URL. Content-Type must be exactly the image/jpeg the presign request
  // declared — SigV4 signs it.
  if (res.getStatus() === 200) {
    bru.setVar("uploadKey", res.getBody().key);
    const axios = require("axios");
    const tinyJpeg = Buffer.from("", "base64");
    await axios.put(res.getBody().uploadUrl, tinyJpeg, {
      headers: { "Content-Type": "image/jpeg" },
    });
  }
}
