{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "IdentityServiceUrl": "https://localhost:5001",
  "ReverseProxy": {
    "Clusters": {
      // Identity Service (Phase 11 Task 7) — same dev address ("IdentityServiceUrl" above)
      // already used as this gateway's own JwtBearer Authority, and as every other service's
      // Authority. Backs the "admin-users"/"admin-users-catchall"/"openapi-identity" routes in
      // appsettings.json.
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:5001"
          }
        }
      },
      "auction-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5054"
          }
        }
      },
      "search-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5055"
          }
        }
      },
      // Bidding Service (Phase 5) — dev port 7003 (BiddingService.API's own launchSettings.json).
      "bidding-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:7003"
          }
        }
      },
      // Notification Service doesn't exist yet (Phase 6) — placeholder, configurable dev address.
      "notification-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:7004"
          }
        }
      }
    }
  }
}
