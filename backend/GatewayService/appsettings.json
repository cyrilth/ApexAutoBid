{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      // ── Auction Service (Architecture.md §3.5) ──────────────────────────────
      // Split into read (GET, anonymous) vs. write (POST/PUT/DELETE, authenticated) routes
      // per path shape — a bare "/api/auctions" entry for the collection endpoints (list/
      // create) and a "{**catch-all}" entry for item-scoped endpoints (get/update/delete by
      // id, upload-url, thumbnail). The Auction Service's own "EmailVerified" policy and
      // seller-ownership checks are enforced downstream, not here.
      // RateLimiterPolicy ("general" vs "strict") references the named policies registered in
      // Program.cs (Task 8/8.1) — same "attach a policy name from appsettings.json" pattern as
      // AuthorizationPolicy above, just for a different ASP.NET Core middleware.
      "auctions-read": {
        "ClusterId": "auction-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/api/auctions",
          "Methods": [ "GET" ]
        }
      },
      "auctions-read-catchall": {
        "ClusterId": "auction-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/api/auctions/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      // "strict" (not "general") — mutating auction endpoints, per Requirements §3.5's
      // stricter-policy list (Task 8.1).
      "auctions-write": {
        "ClusterId": "auction-cluster",
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "strict",
        "Match": {
          "Path": "/api/auctions",
          "Methods": [ "POST" ]
        }
      },
      "auctions-write-catchall": {
        "ClusterId": "auction-cluster",
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "strict",
        "Match": {
          "Path": "/api/auctions/{**catch-all}",
          "Methods": [ "POST", "PUT", "DELETE" ]
        }
      },

      // ── Search Service (Architecture.md §3.5) ───────────────────────────────
      // Read-only, anonymous — GET api/search?searchTerm=... (query strings aren't part of
      // path matching, so the bare route already covers every query-parameter combination);
      // the catch-all entry is future-proofing for path-scoped sub-resources.
      "search": {
        "ClusterId": "search-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/api/search",
          "Methods": [ "GET" ]
        }
      },
      "search-catchall": {
        "ClusterId": "search-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/api/search/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },

      // ── Aggregated OpenAPI documents (Architecture.md §7/§9-10, Task 7.1) ───
      // Proxies each service's own /openapi/v1.json through YARP at a stable, service-scoped
      // gateway path (/openapi/{svc}/v1.json), so the aggregated Scalar page mapped in
      // Program.cs (Task 7.2) can reference one path per service without the gateway ever
      // generating a document of its own. PathSet rewrites the incoming request path to the
      // cluster's real document path before forwarding — the "/openapi/{svc}/v1.json" shape
      // is gateway-only and never reaches the downstream service. Anonymous + "general" like
      // any other read-only, non-sensitive route. Only Auction and Search exist today; adding
      // Bidding's or the Identity admin API's own document later (Phase 5/11) is a matter of
      // adding one more route entry here (same ClusterId already used by that service's other
      // routes) plus one more Program.cs AddDocument call — no other code changes required.
      "openapi-auction": {
        "ClusterId": "auction-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/openapi/auction/v1.json",
          "Methods": [ "GET" ]
        },
        "Transforms": [
          { "PathSet": "/openapi/v1.json" }
        ]
      },
      "openapi-search": {
        "ClusterId": "search-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/openapi/search/v1.json",
          "Methods": [ "GET" ]
        },
        "Transforms": [
          { "PathSet": "/openapi/v1.json" }
        ]
      },
      // Bidding Service's own OpenAPI document (Phase 5 Task 18) — same PathSet-rewrite
      // pattern as "openapi-auction"/"openapi-search" above; ClusterId reuses the
      // "bidding-cluster" the "bids-place"/"bids-read" routes below already declare.
      "openapi-bidding": {
        "ClusterId": "bidding-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/openapi/bidding/v1.json",
          "Methods": [ "GET" ]
        },
        "Transforms": [
          { "PathSet": "/openapi/v1.json" }
        ]
      },
      // Identity Service's admin API document (Phase 11 Task 2.8/7.4) — same PathSet-rewrite
      // pattern as the three documents above; ClusterId reuses the new "identity-cluster" the
      // "admin-users"/"admin-users-catchall" routes above already declare. Anonymous + "general"
      // like every other OpenAPI-document proxy route: the document itself carries no secrets,
      // and Scalar's "Authorize" flow (Program.cs) is what actually gates calling the real
      // admin-role-protected operations it describes, not fetching the document.
      "openapi-identity": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/openapi/identity/v1.json",
          "Methods": [ "GET" ]
        },
        "Transforms": [
          { "PathSet": "/openapi/v1.json" }
        ]
      },

      // ── Bidding Service (Architecture.md §3.5) ──────────────────────────────
      // POST api/bids (place bid) requires an authenticated user; GET api/bids/{auctionId}
      // (bid history) stays anonymous. The Bidding Service's own "EmailVerified" policy is
      // enforced downstream, not here.
      "bids-place": {
        "ClusterId": "bidding-cluster",
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "strict",
        "Match": {
          "Path": "/api/bids",
          "Methods": [ "POST" ]
        }
      },
      "bids-read": {
        "ClusterId": "bidding-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/api/bids/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },

      // ── Public Auction Service additions (Phase 11 Task 7) ──────────────────
      // GET api/banners — anonymous list of active banners for the home/auction pages
      // (Requirements.md §10; Docs/Tasks.md Phase 11 Task 3.5/3.6). GET api/auctions/duration-
      // limits (Task 3.8) needs NO new route here — it is already covered by the existing
      // "auctions-read-catchall" entry above ("/api/auctions/{**catch-all}", GET, anonymous,
      // "general"), since that pattern matches any path segment(s) following "/api/auctions/".
      "banners-read": {
        "ClusterId": "auction-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/api/banners",
          "Methods": [ "GET" ]
        }
      },

      // ── Admin routes (Phase 11 Task 7) ──────────────────────────────────────
      // Routed BY RESOURCE SEGMENT (Docs/Tasks.md's own wording) rather than split by HTTP
      // method the way the public auctions-read/-write pairs above are: every admin endpoint —
      // GET list/stats, POST create, PUT update, DELETE remove — requires the same "admin"
      // AuthorizationPolicy (Program.cs's RequireRole("admin")) regardless of verb, so one
      // route per resource covers the base collection path (list/create — e.g. GET/POST
      // api/admin/users) and one "{**catch-all}" sibling covers every item-scoped/child path
      // (e.g. api/admin/users/{id}/roles, and critically api/admin/users/stats — Requirements
      // §10.1's stats endpoint is per-resource specifically so it falls under its own
      // resource's catch-all instead of needing a dedicated route). No Methods restriction on
      // any entry below (mirrors the Methods-omitted "notifications"/"notifications-catchall"
      // pattern already used elsewhere in this file) — every verb an admin endpoint might use
      // is allowed through to the owning service, which still enforces which verbs its own
      // routes actually accept. "general" (not "strict") on every admin route: the sensitive
      // part of admin access is the "admin" AuthorizationPolicy itself (only a caller carrying
      // the admin role claim ever reaches an admin endpoint at all), not the rate-limit tier —
      // an admin dashboard's own usage pattern (paging user/auction/bid lists, polling stats
      // endpoints) is closer to the generous anonymous-read budget than the public,
      // unauthenticated-flood-focused "strict" budget shared by the public auction/bid mutating
      // routes above, and per-client-IP partitioning already keeps one admin's usage from ever
      // affecting another caller's budget regardless of which named policy is used.
      //
      // users* → Identity Service (identity-cluster, appsettings.Development.json — new cluster
      // added alongside this task; Identity Service listens at IdentityServiceUrl,
      // https://localhost:5001 in dev, same address already used as this gateway's own
      // JwtBearer Authority).
      "admin-users": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "admin",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/api/admin/users"
        }
      },
      "admin-users-catchall": {
        "ClusterId": "identity-cluster",
        "AuthorizationPolicy": "admin",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/api/admin/users/{**catch-all}"
        }
      },

      // auctions*/banners*/settings* → Auction Service (auction-cluster — same cluster the
      // public auctions-read/-write and banners-read routes above already use).
      "admin-auctions": {
        "ClusterId": "auction-cluster",
        "AuthorizationPolicy": "admin",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/api/admin/auctions"
        }
      },
      "admin-auctions-catchall": {
        "ClusterId": "auction-cluster",
        "AuthorizationPolicy": "admin",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/api/admin/auctions/{**catch-all}"
        }
      },
      "admin-banners": {
        "ClusterId": "auction-cluster",
        "AuthorizationPolicy": "admin",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/api/admin/banners"
        }
      },
      "admin-banners-catchall": {
        "ClusterId": "auction-cluster",
        "AuthorizationPolicy": "admin",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/api/admin/banners/{**catch-all}"
        }
      },
      "admin-settings": {
        "ClusterId": "auction-cluster",
        "AuthorizationPolicy": "admin",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/api/admin/settings"
        }
      },
      "admin-settings-catchall": {
        "ClusterId": "auction-cluster",
        "AuthorizationPolicy": "admin",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/api/admin/settings/{**catch-all}"
        }
      },

      // bids* → Bidding Service (bidding-cluster — same cluster the public bids-place/bids-read
      // routes above already use).
      "admin-bids": {
        "ClusterId": "bidding-cluster",
        "AuthorizationPolicy": "admin",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/api/admin/bids"
        }
      },
      "admin-bids-catchall": {
        "ClusterId": "bidding-cluster",
        "AuthorizationPolicy": "admin",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/api/admin/bids/{**catch-all}"
        }
      },

      // ── Notification Service (Architecture.md §3.5 — prep for Phase 6) ──────
      // No Methods restriction: the SignalR hub itself uses a mix of verbs (GET for the
      // WebSocket upgrade / SSE, POST for negotiate and long-polling sends) that YARP passes
      // through unchanged (WebSockets pass through YARP by default). Anonymous at the gateway
      // — anonymous connections are allowed (broadcast-only); the hub enforces its own
      // per-connection JWT (access_token query parameter) for targeted messages once built.
      "notifications": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/notifications"
        }
      },
      "notifications-catchall": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/notifications/{**catch-all}"
        }
      }
    }
  },

  // ── Rate limiting (Task 8/8.1) ────────────────────────────────────────────────
  //
  // Non-sensitive, environment-agnostic defaults (CLAUDE.md Configuration convention) for the
  // two named fixed-window-per-client-IP policies registered in Program.cs. "General" covers
  // every proxied route plus the gateway's own GET api/version and /scalar; "Mutating" is the
  // stricter policy attached only to the write routes above (POST api/bids, POST/PUT/DELETE
  // api/auctions). Both are plain request-count-per-window values — no secrets — so they live
  // here rather than in appsettings.Development.json.
  "RateLimiting": {
    "General": {
      "PermitLimit": 100,
      "WindowSeconds": 60
    },
    "Mutating": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    }
  }
}
