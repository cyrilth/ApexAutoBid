{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      // ── Auction Service (Architecture.md §3.5) ──────────────────────────────
      // Split into read (GET, anonymous) vs. write (POST/PUT/DELETE, authenticated) routes
      // per path shape — a bare "/api/auctions" entry for the collection endpoints (list/
      // create) and a "{**catch-all}" entry for item-scoped endpoints (get/update/delete by
      // id, upload-url, thumbnail). The Auction Service's own "EmailVerified" policy and
      // seller-ownership checks are enforced downstream, not here.
      // RateLimiterPolicy ("general" vs "strict") references the named policies registered in
      // Program.cs (Task 8/8.1) — same "attach a policy name from appsettings.json" pattern as
      // AuthorizationPolicy above, just for a different ASP.NET Core middleware.
      "auctions-read": {
        "ClusterId": "auction-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/api/auctions",
          "Methods": [ "GET" ]
        }
      },
      "auctions-read-catchall": {
        "ClusterId": "auction-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/api/auctions/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },
      // "strict" (not "general") — mutating auction endpoints, per Requirements §3.5's
      // stricter-policy list (Task 8.1).
      "auctions-write": {
        "ClusterId": "auction-cluster",
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "strict",
        "Match": {
          "Path": "/api/auctions",
          "Methods": [ "POST" ]
        }
      },
      "auctions-write-catchall": {
        "ClusterId": "auction-cluster",
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "strict",
        "Match": {
          "Path": "/api/auctions/{**catch-all}",
          "Methods": [ "POST", "PUT", "DELETE" ]
        }
      },

      // ── Search Service (Architecture.md §3.5) ───────────────────────────────
      // Read-only, anonymous — GET api/search?searchTerm=... (query strings aren't part of
      // path matching, so the bare route already covers every query-parameter combination);
      // the catch-all entry is future-proofing for path-scoped sub-resources.
      "search": {
        "ClusterId": "search-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/api/search",
          "Methods": [ "GET" ]
        }
      },
      "search-catchall": {
        "ClusterId": "search-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/api/search/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },

      // ── Aggregated OpenAPI documents (Architecture.md §7/§9-10, Task 7.1) ───
      // Proxies each service's own /openapi/v1.json through YARP at a stable, service-scoped
      // gateway path (/openapi/{svc}/v1.json), so the aggregated Scalar page mapped in
      // Program.cs (Task 7.2) can reference one path per service without the gateway ever
      // generating a document of its own. PathSet rewrites the incoming request path to the
      // cluster's real document path before forwarding — the "/openapi/{svc}/v1.json" shape
      // is gateway-only and never reaches the downstream service. Anonymous + "general" like
      // any other read-only, non-sensitive route. Only Auction and Search exist today; adding
      // Bidding's or the Identity admin API's own document later (Phase 5/11) is a matter of
      // adding one more route entry here (same ClusterId already used by that service's other
      // routes) plus one more Program.cs AddDocument call — no other code changes required.
      "openapi-auction": {
        "ClusterId": "auction-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/openapi/auction/v1.json",
          "Methods": [ "GET" ]
        },
        "Transforms": [
          { "PathSet": "/openapi/v1.json" }
        ]
      },
      "openapi-search": {
        "ClusterId": "search-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/openapi/search/v1.json",
          "Methods": [ "GET" ]
        },
        "Transforms": [
          { "PathSet": "/openapi/v1.json" }
        ]
      },

      // ── Bidding Service (Architecture.md §3.5 — prep for Phase 5) ───────────
      // POST api/bids (place bid) requires an authenticated user; GET api/bids/{auctionId}
      // (bid history) stays anonymous. The Bidding Service's own "EmailVerified" policy is
      // enforced downstream, not here.
      "bids-place": {
        "ClusterId": "bidding-cluster",
        "AuthorizationPolicy": "authenticated",
        "RateLimiterPolicy": "strict",
        "Match": {
          "Path": "/api/bids",
          "Methods": [ "POST" ]
        }
      },
      "bids-read": {
        "ClusterId": "bidding-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/api/bids/{**catch-all}",
          "Methods": [ "GET" ]
        }
      },

      // ── Notification Service (Architecture.md §3.5 — prep for Phase 6) ──────
      // No Methods restriction: the SignalR hub itself uses a mix of verbs (GET for the
      // WebSocket upgrade / SSE, POST for negotiate and long-polling sends) that YARP passes
      // through unchanged (WebSockets pass through YARP by default). Anonymous at the gateway
      // — anonymous connections are allowed (broadcast-only); the hub enforces its own
      // per-connection JWT (access_token query parameter) for targeted messages once built.
      "notifications": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/notifications"
        }
      },
      "notifications-catchall": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "anonymous",
        "RateLimiterPolicy": "general",
        "Match": {
          "Path": "/notifications/{**catch-all}"
        }
      }
    }
  },

  // ── Rate limiting (Task 8/8.1) ────────────────────────────────────────────────
  //
  // Non-sensitive, environment-agnostic defaults (CLAUDE.md Configuration convention) for the
  // two named fixed-window-per-client-IP policies registered in Program.cs. "General" covers
  // every proxied route plus the gateway's own GET api/version and /scalar; "Mutating" is the
  // stricter policy attached only to the write routes above (POST api/bids, POST/PUT/DELETE
  // api/auctions). Both are plain request-count-per-window values — no secrets — so they live
  // here rather than in appsettings.Development.json.
  "RateLimiting": {
    "General": {
      "PermitLimit": 100,
      "WindowSeconds": 60
    },
    "Mutating": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    }
  }
}
