{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  // Restricted (not "*") so HostFilteringMiddleware 400s forged Host headers — Register builds
  // the email-confirmation link from Request.Host, so an unrestricted value would let an
  // attacker-supplied Host header poison that link (host-header injection). Deployments serving
  // other hostnames must override this (env var ALLOWEDHOSTS or per-environment config).
  "AllowedHosts": "localhost",
  "Smtp": {
    "Host": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "UseSsl": true,
    "FromAddress": "noreply@apexautobid.local",
    "FromName": "ApexAutoBid"
  },
  // Empty placeholders — production Turnstile keys are real external credentials, supplied via
  // environment variables only (Turnstile__SiteKey / Turnstile__SecretKey), never committed, same
  // rule as the Google OAuth credentials (Phase 3 Task 15). Dev/Docker values (Cloudflare's own
  // official always-pass test keys) live in appsettings.Development.json only.
  "Turnstile": {
    "SiteKey": "",
    "SecretKey": "",
    "VerifyUrl": "https://challenges.cloudflare.com/turnstile/v0/siteverify"
  },
  // Non-sensitive — safe to commit as-is in every environment. PermitLimit/WindowSeconds per
  // client IP; see HostingExtensions.cs's GlobalLimiter for how these are applied.
  "RateLimiting": {
    "Login": { "PermitLimit": 10, "WindowSeconds": 60 },
    "Register": { "PermitLimit": 5, "WindowSeconds": 60 },
    "Token": { "PermitLimit": 30, "WindowSeconds": 60 }
  }
}