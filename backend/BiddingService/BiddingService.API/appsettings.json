{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RabbitMq": {
    "Host": "localhost"
  },
  "Bidding": {
    // Phase 5 Task 12 / Requirements §3.3 — the background finalizer's check interval. Env
    // var override form: Bidding__FinalizationIntervalSeconds. Non-sensitive, environment-
    // agnostic default (CLAUDE.md Configuration convention) — 10s keeps short dev/demo
    // auctions (e.g. the seed data's own +6 hour and already-past-AuctionEnd cases) finalizing
    // promptly, so it lives here rather than only in appsettings.Development.json.
    "FinalizationIntervalSeconds": 10,
    // Phase-end code review Critical 2 — grace period added past AuctionEnd before an auction
    // becomes eligible for finalization (FinalizationOptions' own remarks have the full
    // rationale): comfortably longer than this service's own bus-outbox commit/publish
    // round-trip under normal load, without meaningfully delaying finalization of auctions with
    // no last-second bidding. Env var override form: Bidding__FinalizationGraceSeconds.
    "FinalizationGraceSeconds": 10
  }
}
