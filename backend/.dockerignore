# Host build artifacts must never be copied into the image — the container does
# its own restore/build. Copying host obj/ can break the in-container build.
**/bin/
**/obj/
**/out/

# IDE / editor state
.vs/
.vscode/
**/*.user

# Docker & VCS noise (the Dockerfile is supplied via -f, not needed in context)
**/Dockerfile
**/.dockerignore
.git/
.gitignore

# Duende IdentityServer Automatic Key Management — signing keys persisted to disk at dev
# runtime (Data Protection-encrypted, machine-specific; gitignored — see root .gitignore).
# COPY IdentityService/ IdentityService/ would otherwise bake the host's dev signing key
# into the image; the container generates its own on first run.
IdentityService/keys/
